{
    "compilerOptions": {
        "composite": true,
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
        "target": "ES2023",
        "lib": ["ES2023"],
        "module": "ESNext",
        "types": ["node"],
        "skipLibCheck": true,

        "moduleResolution": "bundler",
        "verbatimModuleSyntax": true,
        "moduleDetection": "force",

        // A composite project has to emit, and nothing consumes the output of the build tooling config,
        // so the declarations it has to produce go to a scratch folder rather than into the source tree.
        "emitDeclarationOnly": true,
        "declarationDir": "./node_modules/.tmp/node-types",

        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "erasableSyntaxOnly": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedSideEffectImports": true
    },
    "include": ["vite.config.ts"]
}
