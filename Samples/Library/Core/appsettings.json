{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Library": {
        "Database": {
            "Provider": "Postgres",
            "InitializeOnStartup": true,
            "SeedOnStartup": true
        },
        "Simulation": {
            "BaseAddress": "",
            "DefaultTransactionCount": 10000,
            "Concurrency": 8,
            "DelayMilliseconds": 0
        }
    }
}
