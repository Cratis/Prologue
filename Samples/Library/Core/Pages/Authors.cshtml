@page "/authors"
@model AuthorsModel
@{
    ViewData["Title"] = "Authors";
}

<h1 class="page-title" data-testid="page-title">Authors</h1>
<p class="page-subtitle">The people the library holds books by.</p>

<partial name="_Error" model="Model.Error" />

<section class="card">
    <h2 class="card-title">Register author</h2>
    <form class="form-row" data-testid="author-form" method="post" asp-page-handler="Register">
        <label class="field">
            <span>First name</span>
            <input class="input" data-testid="author-first-name" name="FirstName" autocomplete="off" />
        </label>
        <label class="field">
            <span>Last name</span>
            <input class="input" data-testid="author-last-name" name="LastName" autocomplete="off" />
        </label>
        <button class="button" data-testid="author-submit" type="submit">Register</button>
    </form>
</section>

<section class="card">
    <div class="table-scroll">
        <table class="table" data-testid="authors-table">
            <thead>
                <tr>
                    <th>First name</th>
                    <th>Last name</th>
                    <th>Books</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var author in Model.Authors)
                {
                    <tr data-testid="author-row" data-id="@author.AuthorId">
                        <td>@author.FirstName</td>
                        <td>@author.LastName</td>
                        <td class="numeric">@author.BookCount</td>
                        <td>
                            <form method="post" asp-page-handler="Delete">
                                <input type="hidden" name="AuthorId" value="@author.AuthorId" />
                                <button class="button button-danger" data-testid="author-delete" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Authors.Count == 0)
    {
        <div class="empty">No authors registered yet.</div>
    }
</section>
